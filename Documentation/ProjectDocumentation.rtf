{\par
    conn.Open();\par
    using (var cmd = new SqlCommand("SELECT TOP 10 * FROM Students", conn))\par
    using (var reader = cmd.ExecuteReader())\par
    {\par
        while (reader.Read())\par
        {\par
            // read fields: reader["FirstName"].ToString();\par
        }\par
    }\par
}\par
\par
// Example: simple login check against a Users table\par
string loginQuery = "SELECT COUNT(1) FROM Users WHERE Username=@u AND PasswordHash=@p";\par
using (var cmd = new SqlCommand(loginQuery, conn))\par
{\par
    cmd.Parameters.AddWithValue("@u", username);\par
    cmd.Parameters.AddWithValue("@p", passwordHash);\par
    int count = Convert.ToInt32(cmd.ExecuteScalar());\par
    bool success = (count > 0);\par
}\par
\f0\fs24
\par
\b 6. Testing checklist\b0\par
- Verify DB connection strings and connectivity in SSMS.\par
- Test create/read/update/delete (CRUD) operations for at least one table.\par
- Test login and registration workflows (valid and invalid inputs).\par
- Validate UI responsiveness and control tab order.\par
\par
\b 7. Preparing the Word submission\b0\par
1. Open Microsoft Word and create a new document.\par
2. Create a cover page with project title, your name, date, and brief description.\par
3. For each form in the system (e.g., Login, Registration, Main Dashboard):\par
   - Insert a screenshot (Insert > Pictures).\par
   - Provide a short description of the form purpose.\par
   - Paste the relevant code snippet for form logic (use `Courier New` font).\par
4. Include the SQL script used to create the database (as a code snippet).\par
5. Add a section for testing results and any known issues.\par
6. Add the project brief and submission checklist.\par
7. Save the Word document as `SkillsProject_Report.docx` and include it in submission.
\par
\b 8. Project brief (example summary to include)\b0\par
- Objective: Build a Windows Forms application for managing student records for Skills International School.\par
- Key features: User authentication (Login), Student registration, Student list and search, Basic reporting/print.\par
- Technologies: .NET Framework 4.7.2, Windows Forms, SQL Server (database), Visual Studio (IDE).\par
- Deliverables: Source code, database script (.sql), `SkillsProject_Report.docx` with screenshots and code snippets.
\par
